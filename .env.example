# ─────────────────────────────────────────────────────────────────────────────
# Environment variables — copy to .env and fill in values
# DO NOT commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://kmmzavod:change_me_strong_password@localhost:5433/kmmzavod

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=kmmzavod
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=kmmzavod
MINIO_SECRET_KEY=change_me_minio_password
MINIO_BUCKET=kmmzavod
MINIO_SECURE=false
MINIO_PUBLIC_HOST=                    # Public hostname for MinIO (e.g. storage.example.com)

# ── Auth (API) ────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── AI Service Keys (orchestrator) ────────────────────────────────────────────
GPTUNNEL_API_KEY=sk-...
GPTUNNEL_BASE_URL=https://gptunnel.ru/v1
HEYGEN_API_KEY=...
RUNWAY_API_KEY=...
KLING_ACCESS_KEY=...
KLING_SECRET_KEY=...
IMAGE_GEN_PROVIDER=fal                # fal | replicate | comfyui | runway
IMAGE_GEN_API_KEY=...

# ── Video Processor ───────────────────────────────────────────────────────────
VIDEO_PROCESSOR_URL=http://localhost:8000

# ── Social Publishing (optional — leave blank to disable) ─────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ── Public URLs (frontend) ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
