# ─────────────────────────────────────────────────────────────────────────────
# Environment variables — copy to .env and fill in values
# DO NOT commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
# Development (host): localhost:5433 | Production (Docker): postgres:5432
DATABASE_URL=postgresql://kmmzavod:change_me_strong_password@localhost:5433/kmmzavod

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=kmmzavod
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=kmmzavod
MINIO_SECRET_KEY=change_me_minio_password
MINIO_BUCKET=kmmzavod
MINIO_SECURE=false
MINIO_PUBLIC_HOST=                    # Public hostname for MinIO (e.g. storage.example.com)

# ── Auth (API) ────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── AI Service Keys (orchestrator) ────────────────────────────────────────────
GPTUNNEL_API_KEY=sk-...
GPTUNNEL_BASE_URL=https://gptunnel.ru/v1
HEYGEN_API_KEY=...
RUNWAY_API_KEY=...
RUNWAY_VIDEO_MODEL=gen4_turbo           # gen4_turbo (image-to-video, cheap) | gen4.5 (text-to-video)
KLING_ACCESS_KEY=...
KLING_SECRET_KEY=...
IMAGE_GEN_PROVIDER=fal                # fal | replicate | comfyui | runway | gemini
IMAGE_GEN_API_KEY=...
GEMINI_API_KEY=                       # Google AI Studio key (free fallback for image gen)

# ── Video Processor ───────────────────────────────────────────────────────────
VIDEO_PROCESSOR_URL=http://localhost:8000

# ── Social Publishing (optional — leave blank to disable) ─────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
POST_BRIDGE_API_KEY=                  # PostBridge.com cross-posting API key
YOUTUBE_CLIENT_ID=                    # Google OAuth2 client ID for YouTube API
YOUTUBE_CLIENT_SECRET=                # Google OAuth2 client secret for YouTube API

# ── Public URLs (frontend) ────────────────────────────────────────────────────
PUBLIC_API_URL=http://localhost:3000   # Used in docker-compose for NEXT_PUBLIC_API_URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Encryption (optional — for social token encryption at rest) ───────────────
# 32 hex bytes = 64 chars. Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── AI Proxy (for Russian servers — many AI APIs are geo-blocked) ─────────────
# Routes all external AI & social API calls through a proxy.
# Supports: http://, https://, socks5:// (axios), http/https (fetch)
# Example: http://user:pass@proxy.example.com:8080
#          socks5://user:pass@proxy.example.com:1080
AI_PROXY_URL=
